# Q&A Based Interactive Storytelling - Environment Configuration
# Copy this file to .env and update values as needed

# LLM Provider: ollama (local), openai, or gemini
LLM_PROVIDER=ollama

# Ollama Settings (for local LLM)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Settings (optional - for future API use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Google Gemini Settings (optional - for future API use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# Generation Settings
TEMPERATURE=0.8
